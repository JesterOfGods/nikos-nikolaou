# Copy to .env and fill in. Never commit .env.
# Sign up at https://elevenlabs.io — get an API key from your profile.
ELEVENLABS_API_KEY=your_api_key_here

# Voice ID — find one in the ElevenLabs voice library, or use a cloned voice.
# Default below is "Rachel" (a stock voice). Replace with your cloned voice ID when ready.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Model: eleven_multilingual_v2 (high quality) or eleven_turbo_v2_5 (faster, cheaper)
ELEVENLABS_MODEL=eleven_multilingual_v2
